    <button type="submit" class="btn btn-sm" id="btn-save"><i class="fa fa-save"></i>Kaydet</button>
    <a asp-action="Index" class="btn btn-sm" id="btn-cancel" style="margin-right:8px;"><i class="fa fa-undo"></i>İptal</a>
