@using PathojaPilatesProject.Models.Teacher
@model TeacherEditVM

<div class="sidepanel-header">
    <h3>Öğretmen Bilgilerini Düzenle</h3>
    <span class="sidepanel-close" onclick="closeSidePanel('editTeacherPanel')">&times;</span>
</div>

<form asp-action="EditTeacher" asp-controller="Teacher" id="editTeacherForm" method="post">
    <input asp-for="Id" hidden />

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Adı</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label">Soyadı</label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Mail" class="form-label">E-posta:</label>
        <input asp-for="Mail" class="form-control" />
        <span asp-validation-for="Mail" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PhoneNumber" class="form-label"></label>
        <input asp-for="PhoneNumber" class="form-control" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>

