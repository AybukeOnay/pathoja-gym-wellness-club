    <div class="mb-3">
        <label class="form-label">Kategoriler</label>
        <select id="CategoryIds" name="CategoryIds" multiple="multiple"
                asp-for="CategoryIds"
                asp-items="@(ViewBag.Categories as IEnumerable<SelectListItem>)"
                class="form-control select2">
        </select>
        <span asp-validation-for="CategoryIds" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Branşlar</label>
