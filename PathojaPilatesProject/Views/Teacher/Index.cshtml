@using BusinessLayer.DTOs.Teacher
@model List<TeacherListDto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/css/sidePanel.css" />
    <link rel="stylesheet" href="~/css/Admin/Teacher/TeacherListPage.css" />

}

<div class="wrapper-content">
    <h2 class="page-title">Öğretmenler</h2>
    <div class="section-divider"></div>

    <div class="teacher-card-container">
        @foreach (var item in Model)
        {
            <div class="teacher-card" data-id="@item.Id">
                <div class="teacher-image">
                    <img src="@Url.Content(item.Image)" alt="@item.FullName" />
                </div>
                <div class="teacher-details">
                    <h3>@item.FullName</h3>
                    @* <p><strong>Lessons:</strong> @string.Join(", ", item.LessonsName)</p> *@
                    <p><strong>Email:</strong> @item.Mail</p>
                    <p><strong>Phone:</strong> @item.PhoneNumber</p>
                    <p><strong>Branş:</strong> @string.Join(", ", item.Categories)</p>
                    <p><strong>Şube:</strong> @string.Join(", ", item.Branches)</p>
                </div>
            </div>
        }
    </div>
</div>

<div class="d-flex justify-content-between align-items-center">
    <div class="left-buttons d-flex gap-2">
        <a href="#" class="btn btn-sm disabled" id="btn-edit-lesson">
            <i class="fa fa-book"></i> Edit Lessons
        </a>
    </div>

    <div class="right-buttons d-flex gap-2">
        <a asp-action="AddTeacher" asp-controller="Teacher" class="btn btn-sm" id="btn-add">
            <i class="fa fa-plus"></i> Ekle
        </a>
        <a href="#" class="btn btn-sm disabled" id="btn-edit">
            <i class="fa fa-edit"></i> Düzenle
        </a>
        <a href="#" class="btn btn-sm disabled" id="btn-delete">
            <i class="fa fa-trash"></i> Sil
        </a>
    </div>
</div>

<div id="editTeacherPanel" class="sidepanel">
@*     <div class="sidepanel-header">
        <h3>Öğretmen Bilgilerini Düzenle</h3>
        <span class="sidepanel-close" onclick="closeSidePanel('editTeacherPanel')">&times;</span>
    </div> *@
    <div class="sidepanel-body" id="editTeacherPanelBody">
        <!-- Partial view buraya yüklenecek -->
    </div>
</div>
<div id="overlay-backdrop" class="overlay-backdrop"></div>



@section Scripts {
    <script src="~/js/sidepanel.js"></script>
    <script src="~/js/Admin/Teacher/TeacherIndexPage.js"></script>
}
