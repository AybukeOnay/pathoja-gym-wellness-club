@model PathojaPilatesProject.Models.Home.HomePopupEventVM

@{
    ViewData["Title"] = "Pathoja Pilates";
    Layout = "~/Views/Shared/_MainWebSiteLayout.cshtml";
}

@section HeroSection {
    @await Html.PartialAsync("PartialHeroSection")
}

@section WhyUs {
    @await Html.PartialAsync("PartialWhyUs")
}

@section Service {
    @await Html.PartialAsync("PartialService")
}

@section Testimonial {
    @await Html.PartialAsync("PartialMemberTestimonials")
}

@if (Model != null)
{
    @await Html.PartialAsync("_HomePopupEvent", Model)
}
