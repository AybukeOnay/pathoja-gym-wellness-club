
<section id="why-us" class="whyus-section position-relative overflow-hidden">
    <!-- Arka plan şekilleri -->
    <div class="whyus-blob blob-1"></div>
    <div class="whyus-blob blob-2"></div>

    <div class="container py-5 py-md-6">
        <div class="row g-5">
            <!-- Sol: Başlık + çizgisel vurgu + maddeler -->
            <div class="col-lg-6">
                @* <div class="whyus-kicker" data-reveal style="--d:0.0s;">
                    <i class="bi bi-stars me-2"></i> Pathoja GYM & Wellness Club Farkı
                </div> *@

                <h2 class="whyus-title" data-reveal style="--d:0.1s;">
                    Neden <span class="stroke">Pathoja</span>?
                    <!-- Çizgisel vurgu (SVG çizim animasyonu) -->
@*                     <svg class="whyus-underline"
                         viewBox="0 0 520 60"
                         preserveAspectRatio="none"
                         aria-hidden="true">
                        <!-- Dalga tamamen yazının altında gezsin -->
                        <path d="M5 50 Q 140 45 260 52 T 420 50 T 515 52" />
                    </svg> *@
                </h2>

                <p class="whyus-sub" data-reveal style="--d:0.2s;">
                    Pilates, fitness, yoga, crossfit, dans ve raket sporlarını bir araya getiren,
                    hedeflerinize ve yaşam ritminize göre şekillenen bütünsel bir wellness deneyimi.
                </p>

                <ul class="whyus-list">
                    <li data-reveal style="--d:0.3s;">
                        <i class="bi bi-check2-circle"></i>
                        <div>
                            <strong>Uzman eğitmen kadrosu</strong>
                            <span>Farklı branşlarda deneyimli, güncel yaklaşımlarla destek sunan profesyonel bir ekip.</span>
                        </div>
                    </li>
                    <li data-reveal style="--d:0.35s;">
                        <i class="bi bi-check2-circle"></i>
                        <div>
                            <strong>Kişiye özel programlar</strong>
                            <span>Seviyenize, hedefinize ve ilgi alanlarınıza göre şekillenen esnek planlama.</span>
                        </div>
                    </li>
                    <li data-reveal style="--d:0.4s;">
                        <i class="bi bi-check2-circle"></i>
                        <div>
                            <strong>Çok branşlı deneyim</strong>
                            <span>Tek bir çatı altında güç, denge, mobilite, performans ve sosyal hareket alanları.</span>
                        </div>
                    </li>
                    <li data-reveal style="--d:0.45s;">
                        <i class="bi bi-check2-circle"></i>
                        <div>
                            <strong>Konforlu ve ilham veren ortam</strong>
                            <span>Motivasyonu destekleyen, düzenli ve keyifli bir kulüp atmosferi.</span>
                        </div>
                    </li>
                </ul>
            </div>

            <!-- Sağ: Sayılar + kart animasyonları -->
            <div class="col-lg-6 whyus-right-col">
                <div class="row g-3 g-md-4">
                    <div class="col-6">
                        <div class="whyus-card" data-reveal style="--d:0.25s;">
                            <i class="bi bi-heart-pulse"></i>
                            <div class="metric">
                                <span class="countup" data-to="98">0</span><span>%</span>
                            </div>
                            <p>Memnuniyet</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="whyus-card" data-reveal style="--d:0.3s;">
                            <i class="bi bi-people"></i>
                            <div class="metric">
                                <span class="countup" data-to="1000">0</span>+
                            </div>
                            <p>Üye Deneyimi</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="whyus-card" data-reveal style="--d:0.35s;">
                            <i class="bi bi-clock-history"></i>
                            <div class="metric">
                                <span class="countup" data-to="50">0</span><span> dk</span>
                            </div>
                            <p>Odaklı Seans</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="whyus-card" data-reveal style="--d:0.4s;">
                            <i class="bi bi-person-check"></i>
                            <div class="metric">
                                <span class="countup" data-to="1">0</span><span>-on-1</span>
                            </div>
                            <p>Kişisel İlgi</p>
                        </div>
                    </div>
                </div>

                <!-- Alt kısım: kayan avantaj bandı -->
                <div class="whyus-ticker-wrap" data-reveal style="--d:0.5s;">
                    <div class="whyus-ticker">
                        <span><i class="bi bi-dot"></i>Pilates</span>
                        <span><i class="bi bi-dot"></i>Fitness</span>
                        <span><i class="bi bi-dot"></i>Yoga</span>
                        <span><i class="bi bi-dot"></i>Crossfit</span>
                        <span><i class="bi bi-dot"></i>Dans</span>
                        <span><i class="bi bi-dot"></i>Padel Tenis</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

